<?xml version="1.0" encoding="UTF-8"?>
<!--
  Kettle file-repository DEFINITION for the lab.

  The pipeline content (.ktr/.kjb) lives under a separate `pipelines/`
  tree, organised by scenario:

    pipelines/demo/hello_world.ktr        -> repo path /demo/hello_world
    pipelines/CSCU/extract_transactions.ktr -> repo path /CSCU/extract_transactions

  so <base_directory> below points at that `pipelines` folder.

  `scripts/deploy.ps1` stages this under the install:
    - content   -> C:\PDI-Airflow\pipelines\<scenario>\
    - this file -> C:\PDI-Airflow\repositories\repositories.xml
                   (base_directory rewritten to C:\PDI-Airflow\pipelines)
  and `run-carte.ps1` syncs it into C:\PDI-Airflow\.kettle\ (what Carte
  actually reads, via KETTLE_HOME) so your global ~/.kettle is untouched.
-->
<repositories>
  <repository>
    <id>KettleFileRepository</id>
    <name>Default</name>
    <description>Lab file repository</description>
    <base_directory>C:\PDI-Airflow\pipelines</base_directory>
    <read_only>N</read_only>
    <hides_hidden_files>N</hides_hidden_files>
  </repository>
</repositories>
