# Lab configuration. Copy to `.env` (docker compose reads it
# automatically) and adjust for your network.
#
#   cp .env.example .env
#
# Topology this lab targets:
#   - This Ubuntu 24.04 host runs the Airflow + Marquez containers
#     (and, typically, PDC alongside them).
#   - Carte / PDI runs on a separate Windows 11 machine.
# So point CARTE_HOST at the Windows machine's LAN IP.

# --- Carte / PDI (on the Windows 11 machine) ---
# The single-server topology. Becomes the env-var connection pdi_default
# (host:port the Airflow container POSTs executeTrans/executeJob to).
CARTE_HOST=192.168.1.100
CARTE_PORT=8081
CARTE_USER=cluster
CARTE_PASSWORD=cluster

# --- Carte cluster master (for the seeded pdi_cluster connection) ---
# The cluster topology: Airflow submits to the master, which fans the
# transformation out to its slaves (the .ktr carries the cluster schema).
# airflow-init seeds a DB connection `pdi_cluster` from these, so it
# appears in the Studio's connection picker. Defaults match the local
# cluster started by run-carte-cluster.ps1 (master :8081 + slaves
# :8082/:8083 on the Windows machine). Edit to your real master's address.
CLUSTER_HOST=192.168.1.100
CLUSTER_PORT=8081

# --- PDI repository login (the Carte executeJob/Trans user/pass) ---
# Shared by both connections above.
PDI_REPO=Default
PDI_REPO_USER=admin
PDI_REPO_PASSWORD=password

# --- DAGs folder mounted into Airflow ---
# The parent folder Airflow scans recursively — workshop/, examples/ and
# deploy-target/ under it all load. The Studio's `DAGs folder` setting
# should point at the deploy-target/ subfolder so generated DAGs land
# there, separate from the pre-built examples.
#   Ubuntu VM:  a path on the VM, e.g. ~/PDI-Airflow/workshop/dags
#   Windows:    C:\PDI-Airflow\DAGs  (see docker-compose.win.yml)
DAGS_DIR=../../workshop/dags

# --- Airflow internal secret ---
# Shared by every Airflow component. Left unset each container generates
# its own random key, so tokens minted by one fail validation in another
# and you get "please make sure that all your Airflow components have the
# same 'secret_key' configured". The compose default is fine for a lab -
# set your own for anything reachable beyond it.
AIRFLOW_SECRET_KEY=pdi-airflow-lab-secret-key-change-me
