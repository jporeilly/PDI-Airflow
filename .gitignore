# Python
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/
.venv/
.airflow/
.pytest_cache/
.coverage
htmlcov/

# Node / Vite
node_modules/

# Editors
.idea/
.vscode/

# Secrets & local config (never commit)
.env
webapp/settings.json

# Generated / local artifacts
# DAGs students generate and deploy during the workshop (Module 11) land
# in deploy-target/; keep the folder (README + .gitkeep) but ignore deploys.
workshop/dags/deploy-target/*.py
*.openlineage.json
_pdc_share/
webapp/logs/

# Kettle/Pentaho runtime state synced in by run-carte*.ps1.
# These carry credentials (shared.xml DB passwords, metastore VFS keys) -
# never commit them, even if the launcher is run from a source clone.
.kettle/
.pentaho/
**/shared.xml
