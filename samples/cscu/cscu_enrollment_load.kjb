<?xml version="1.0" encoding="UTF-8"?>
<job>
  <name>cscu_enrollment_load</name>
  <description>CSCU nightly enrollment load: extract to staging, then build the student mart.</description>
  <directory>/home/cscu/etl</directory>
  <parameters>
    <parameter><name>term</name><default_value>FALL2026</default_value></parameter>
  </parameters>
  <entries>
    <entry><name>Start</name><type>SPECIAL</type><start>Y</start></entry>
    <entry>
      <name>Extract Enrollment</name>
      <type>TRANS</type>
      <transname>extract_enrollment</transname>
      <directory>/home/cscu/etl</directory>
    </entry>
    <entry>
      <name>Build Student Mart</name>
      <type>TRANS</type>
      <transname>build_student_mart</transname>
      <directory>/home/cscu/etl</directory>
    </entry>
    <entry><name>Success</name><type>SUCCESS</type></entry>
  </entries>
  <hops>
    <hop><from>Start</from><to>Extract Enrollment</to><enabled>Y</enabled><unconditional>Y</unconditional></hop>
    <hop><from>Extract Enrollment</from><to>Build Student Mart</to><enabled>Y</enabled><evaluation>Y</evaluation></hop>
    <hop><from>Build Student Mart</from><to>Success</to><enabled>Y</enabled><evaluation>Y</evaluation></hop>
  </hops>
</job>
