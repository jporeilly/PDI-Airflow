<?xml version="1.0" encoding="UTF-8"?>
<transformation>
  <info>
    <name>build_student_mart</name>
    <description>Join staged enrollment with the student dimension into the reporting mart.</description>
    <directory>/home/cscu/etl</directory>
    <parameters/>
  </info>
  <connection>
    <name>cscu-warehouse</name>
    <server>cscu-dw</server>
    <type>POSTGRESQL</type>
    <access>Native</access>
    <database>cscu_dw</database>
    <username>dw_loader</username>
    <port>5432</port>
  </connection>
  <step>
    <name>Read Staging</name>
    <type>TableInput</type>
    <connection>cscu-warehouse</connection>
    <sql>SELECT e.student_id, e.course_id, e.term, e.credits, s.program, s.class_level
FROM staging.enrollment_stg e
JOIN dim.student s ON s.student_id = e.student_id</sql>
  </step>
  <step>
    <name>Write Mart</name>
    <type>TableOutput</type>
    <connection>cscu-warehouse</connection>
    <schema>mart</schema>
    <table>student_enrollment_fact</table>
  </step>
  <order>
    <hop><from>Read Staging</from><to>Write Mart</to><enabled>Y</enabled></hop>
  </order>
</transformation>
