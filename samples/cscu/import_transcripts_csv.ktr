<?xml version="1.0" encoding="UTF-8"?>
<transformation>
  <info>
    <name>import_transcripts_csv</name>
    <description>Load a transcripts CSV export into the warehouse.</description>
    <directory>/home/cscu/etl</directory>
    <parameters/>
  </info>
  <connection>
    <name>cscu-warehouse</name>
    <server>cscu-dw</server>
    <type>POSTGRESQL</type>
    <access>Native</access>
    <database>cscu_dw</database>
    <username>dw_loader</username>
    <port>5432</port>
  </connection>
  <step>
    <name>Read Transcripts CSV</name>
    <type>CsvInput</type>
    <filename>/data/cscu/transcripts_2026.csv</filename>
  </step>
  <step>
    <name>Load Transcripts</name>
    <type>TableOutput</type>
    <connection>cscu-warehouse</connection>
    <schema>staging</schema>
    <table>transcripts_stg</table>
  </step>
  <order>
    <hop><from>Read Transcripts CSV</from><to>Load Transcripts</to><enabled>Y</enabled></hop>
  </order>
</transformation>
