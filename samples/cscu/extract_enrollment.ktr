<?xml version="1.0" encoding="UTF-8"?>
<transformation>
  <info>
    <name>extract_enrollment</name>
    <description>Read raw enrollment records from the CSCU source database.</description>
    <directory>/home/cscu/etl</directory>
    <parameters>
      <parameter><name>term</name><default_value>FALL2026</default_value></parameter>
    </parameters>
  </info>
  <connection>
    <name>cscu-source</name>
    <server>cscu-db</server>
    <type>POSTGRESQL</type>
    <access>Native</access>
    <database>cscu</database>
    <username>cscu_etl</username>
    <port>5432</port>
  </connection>
  <connection>
    <name>cscu-warehouse</name>
    <server>cscu-dw</server>
    <type>POSTGRESQL</type>
    <access>Native</access>
    <database>cscu_dw</database>
    <username>dw_loader</username>
    <port>5432</port>
  </connection>
  <step>
    <name>Read Enrollment</name>
    <type>TableInput</type>
    <connection>cscu-source</connection>
    <sql>SELECT student_id, course_id, term, credits, status
FROM registrar.enrollment
WHERE term = '${term}'</sql>
  </step>
  <step>
    <name>Load Staging</name>
    <type>TableOutput</type>
    <connection>cscu-warehouse</connection>
    <schema>staging</schema>
    <table>enrollment_stg</table>
  </step>
  <order>
    <hop><from>Read Enrollment</from><to>Load Staging</to><enabled>Y</enabled></hop>
  </order>
</transformation>
