<?xml version="1.0" encoding="UTF-8"?>
<job>
  <name>cscu_daily_load</name>
  <description>Copper State Credit Union nightly load: extract posted transactions to staging, then rebuild the member 360 mart. Emails on failure.</description>
  <directory>/CSCU</directory>
  <parameters>
    <parameter><name>since_dt</name><default_value>2026-07-01</default_value></parameter>
  </parameters>
  <entries>
    <entry><name>Start</name><type>SPECIAL</type><start>Y</start></entry>
    <entry>
      <name>Extract Transactions</name>
      <type>TRANS</type>
      <transname>extract_transactions</transname>
      <directory>/CSCU</directory>
    </entry>
    <entry>
      <name>Build Member Mart</name>
      <type>TRANS</type>
      <transname>build_member_mart</transname>
      <directory>/CSCU</directory>
    </entry>
    <entry><name>Mail Failure</name><type>MAIL</type></entry>
    <entry><name>Success</name><type>SUCCESS</type></entry>
  </entries>
  <hops>
    <hop><from>Start</from><to>Extract Transactions</to><enabled>Y</enabled><unconditional>Y</unconditional></hop>
    <hop><from>Extract Transactions</from><to>Build Member Mart</to><enabled>Y</enabled><evaluation>Y</evaluation></hop>
    <hop><from>Extract Transactions</from><to>Mail Failure</to><enabled>Y</enabled><evaluation>N</evaluation></hop>
    <hop><from>Build Member Mart</from><to>Success</to><enabled>Y</enabled><evaluation>Y</evaluation></hop>
    <hop><from>Build Member Mart</from><to>Mail Failure</to><enabled>Y</enabled><evaluation>N</evaluation></hop>
  </hops>
</job>
